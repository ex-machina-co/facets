#!/bin/bash
# Auto-sync strategy submodule to latest remote main before push.
# Safety guards:
#   1. Skip if strategy has uncommitted changes (someone is editing)
#   2. Skip if strategy has been moved from its pinned commit (deliberate change)
# If safe, fetch latest main, update pointer, and amend HEAD commit.

# Guard: uncommitted changes in strategy
if ! git -C strategy diff --quiet 2>/dev/null || \
   ! git -C strategy diff --cached --quiet 2>/dev/null; then
  exit 0
fi

# Guard: strategy moved from pinned commit
PINNED=$(git ls-tree HEAD strategy | awk '{print $3}')
ACTUAL=$(git -C strategy rev-parse HEAD 2>/dev/null)
if [ "$PINNED" != "$ACTUAL" ]; then
  exit 0
fi

# Advance strategy to latest remote main
git submodule update --remote strategy 2>/dev/null
if ! git diff --quiet strategy 2>/dev/null; then
  git add strategy
  git commit --amend --no-edit --no-verify
fi
