{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@ex-machina/facets-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "scripts": {
    "check": "biome check . && bun turbo build types test",
    "lint": "biome check .",
    "format": "biome check . --fix --unsafe",
    "test": "bun turbo test",
    "types": "bun turbo types",
    "build": "bun turbo build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run check && changeset publish --provenance",
    "link": "bun link --cwd packages/facets && bun link --cwd packages/facets-mcp",
    "unlink": "bun unlink --cwd packages/facets && bun unlink --cwd packages/facets-mcp",
    "docs": "bun --cwd docs mint dev"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@changesets/cli": "^2.29.0",
    "@fission-ai/openspec": "^1.2.0",
    "@types/bun": "latest",
    "mint": "4.2.392",
    "turbo": "^2.5.0",
    "typescript": "^5"
  }
}
