{
  "$schema": "https://json.schemastore.org/package.json",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "scripts": {
    "dev": "bun turbo build && bun run link",
    "check": "bun turbo check",
    "change": "changeset",
    "version-packages": "changeset version",
    "release": "bun run check && changeset publish",
    "link": "bun link --cwd packages/cli",
    "unlink": "bun unlink --cwd packages/cli",
    "docs": "bun --cwd docs mint dev"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@changesets/cli": "^2.29.0",
    "@fission-ai/openspec": "^1.2.0",
    "@types/bun": "latest",
    "mint": "4.2.392",
    "turbo": "2.8.17",
    "typescript": "^5"
  }
}
