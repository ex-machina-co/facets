{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": ["bun.lock", "bunfig.toml", "package.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["$TURBO_ROOT$/test-results/**"]
    },
    "types": {
      "dependsOn": []
    },
    "check": {
      "dependsOn": ["//#lint", "types", "test", "//#types"]
    },
    "//#types": {
      "inputs": ["$TURBO_DEFAULT$", "!$TURBO_ROOT$/.changeset/**"]
    },
    "//#lint": {
      "inputs": ["$TURBO_DEFAULT$", "!$TURBO_ROOT$/.changeset/**"]
    }
  },
  "ui": "tui"
}
