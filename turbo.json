{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "types": {
      "dependsOn": []
    },
    "check": {
      "dependsOn": ["//#lint", "types", "test", "//#types"]
    },
    "//#types": {},
    "//#lint": {}
  },
  "ui": "tui"
}
