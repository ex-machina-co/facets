{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": []
    },
    "test": {
      "dependsOn": ["build"]
    },
    "types": {
      "dependsOn": []
    },
    "check": {
      "dependsOn": ["lint", "types", "test"]
    }
  },
  "ui": "tui"
}
